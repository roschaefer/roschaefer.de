{
	"name": "portfolio",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@11.8.0",
	"scripts": {
		"build:paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --emit-ts-declarations",
		"build:typst-data": "node scripts/build-typst-data.ts",
		"build:pdf": "node scripts/build-pdfs.ts",
		"build:vite": "vite build",
		"build:sitemap": "node scripts/build-sitemap.ts",
		"build": "pnpm build:pdf && pnpm build:paraglide && pnpm build:vite && pnpm build:sitemap",
		"dev": "pnpm build:paraglide && vite dev",
		"preview": "vite preview --outDir build",
		"check:types": "pnpm build:paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:quick": "pnpm -s check:quick:run",
		"check:quick:run": "printf 'checking Paraglide messages...\\n' && pnpm -s build:paraglide && printf 'checking lint...\\n' && pnpm -s lint && printf 'checking typecheck...\\n' && pnpm -s check:types && printf 'checking unit tests...\\n' && pnpm -s test:unit",
		"check": "pnpm check:quick && pnpm test:e2e",
		"test": "pnpm test:unit && pnpm test:e2e",
		"test:unit": "pnpm build:paraglide && vitest run",
		"test:e2e": "playwright test",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@biomejs/biome": "^2.5.3",
		"@fontsource-variable/jost": "^5.2.8",
		"@fontsource/titillium-web": "^5.2.8",
		"@inlang/paraglide-js": "^2.21.0",
		"@inlang/plugin-m-function-matcher": "^2.2.9",
		"@inlang/plugin-message-format": "^4.4.0",
		"@jsonresume/schema": "^1.3.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"sitemap": "^9.0.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	}
}
