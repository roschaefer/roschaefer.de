{
	"name": "portfolio",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@11.8.0",
	"scripts": {
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --emit-ts-declarations",
		"dev": "pnpm paraglide:compile && vite dev",
		"build": "pnpm paraglide:compile && pnpm pdf:build && vite build && node scripts/build-sitemap.mjs",
		"preview": "vite preview --outDir build",
		"check": "pnpm paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"pdf:data": "node scripts/build-typst-data.mjs",
		"pdf:build": "node scripts/build-pdfs.mjs",
		"generated:check": "node scripts/check-generated-files.mjs",
		"test": "pnpm test:unit && pnpm test:e2e",
		"test:unit": "pnpm paraglide:compile && vitest run",
		"test:e2e": "playwright test",
		"ready": "pnpm -s ready:run",
		"ready:run": "printf 'checking Paraglide messages...\\n' && pnpm -s paraglide:compile && printf 'checking generated files...\\n' && pnpm -s generated:check && printf 'checking lint...\\n' && pnpm -s lint && printf 'checking typecheck...\\n' && pnpm -s check && printf 'checking unit tests...\\n' && pnpm -s test:unit",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@biomejs/biome": "^2.5.3",
		"@fontsource-variable/jost": "^5.2.8",
		"@fontsource/titillium-web": "^5.2.8",
		"@inlang/paraglide-js": "^2.21.0",
		"@inlang/plugin-m-function-matcher": "^2.2.9",
		"@inlang/plugin-message-format": "^4.4.0",
		"@jsonresume/schema": "^1.3.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"sitemap": "^9.0.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	}
}
