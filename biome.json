{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/.svelte-kit",
			"!**/build",
			"!**/node_modules",
			"!**/project.inlang/.meta.json",
			"!**/resume.json",
			"!**/pnpm-lock.yaml",
			"!**/src/lib/paraglide",
			"!**/typst/content",
			"!**/typst/out",
			"!**/static/resume.de.pdf",
			"!**/static/resume.en.pdf"
		]
	}
}
