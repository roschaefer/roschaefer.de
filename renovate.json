{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"timezone": "Europe/Berlin",
	"schedule": ["before 7am on Monday"],
	"dependencyDashboard": true,
	"configMigration": true,
	"labels": ["dependencies"],
	"semanticCommits": "enabled",
	"semanticCommitType": "chore",
	"prHourlyLimit": 2,
	"prConcurrentLimit": 10,
	"prCreation": "not-pending",
	"internalChecksFilter": "strict",
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/^biome\\.json$/"],
			"matchStrings": [
				"\"\\$schema\":\\s*\"https://biomejs\\.dev/schemas/(?<currentValue>[^/]+)/schema\\.json\""
			],
			"depNameTemplate": "@biomejs/biome",
			"packageNameTemplate": "@biomejs/biome",
			"datasourceTemplate": "npm",
			"versioningTemplate": "semver"
		}
	],
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 7am on Monday"]
	},
	"packageRules": [
		{
			"matchDatasources": ["npm"],
			"minimumReleaseAge": "3 days"
		},
		{
			"matchManagers": ["github-actions"],
			"groupName": "github actions",
			"groupSlug": "github-actions"
		},
		{
			"matchManagers": ["mise"],
			"groupName": "mise tools",
			"groupSlug": "mise-tools"
		},
		{
			"matchPackageNames": ["svelte", "/^@sveltejs\\//"],
			"groupName": "svelte",
			"groupSlug": "svelte"
		},
		{
			"matchPackageNames": ["tailwindcss", "/^@tailwindcss\\//", "/^@fontsource/"],
			"groupName": "styling",
			"groupSlug": "styling"
		},
		{
			"matchPackageNames": ["/^@inlang\\//"],
			"groupName": "i18n",
			"groupSlug": "i18n"
		},
		{
			"matchPackageNames": ["@biomejs/biome"],
			"groupName": "biome",
			"groupSlug": "biome"
		},
		{
			"matchPackageNames": ["typescript", "vite", "vitest", "svelte-check", "/^@types\\//"],
			"groupName": "quality tooling",
			"groupSlug": "quality"
		},
		{
			"matchPackageNames": ["@playwright/test", "mcr.microsoft.com/playwright"],
			"groupName": "playwright",
			"groupSlug": "playwright"
		},
		{
			"matchDepNames": ["pnpm"],
			"groupName": "package manager",
			"groupSlug": "package-manager"
		},
		{
			"matchUpdateTypes": ["major"],
			"dependencyDashboardApproval": true
		}
	]
}
